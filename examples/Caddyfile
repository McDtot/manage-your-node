# Example Caddy reverse proxy for Manage Your Node.
# Caddy fetches and renews a Let's Encrypt certificate automatically.
#
# Usage:
#   1. Point your domain's A/AAAA record at this host.
#   2. Replace panel.example.com with your domain.
#   3. Run the app bound to 127.0.0.1:8787 (default HOST/PORT).
#   4. Export TRUST_X_FORWARDED_FOR=1 so login lockout uses the real client IP.
#   5. caddy run --config ./Caddyfile

panel.example.com {
    encode gzip

    # The app only trusts X-Forwarded-For when TRUST_X_FORWARDED_FOR=1.
    reverse_proxy 127.0.0.1:8787 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Basic hardening headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        -Server
    }
}
