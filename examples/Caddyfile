# Example Caddy reverse proxy for Manage Your Node.
# Caddy fetches and renews a Let's Encrypt certificate automatically.
#
# Usage:
#   1. Point your domain's A/AAAA record at this host.
#   2. Replace panel.example.com with your domain.
#   3. Run the app bound to 127.0.0.1:8787 (default HOST/PORT).
#   4. Set PUBLIC_ORIGIN=https://panel.example.com and ALLOWED_HOSTS=panel.example.com.
#   5. Only enable TRUST_X_FORWARDED_FOR after setting TRUSTED_PROXY_IPS to
#      Caddy's actual source address as seen by the app.
#   6. caddy run --config ./Caddyfile

panel.example.com {
    encode gzip

    reverse_proxy 127.0.0.1:8787 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Basic hardening headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        -Server
    }
}
