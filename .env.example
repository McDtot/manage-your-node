# Copy to .env and fill in real values. Never commit the real .env.
# In non-loopback (production) mode these are REQUIRED or the app refuses to start.

# Long random string. Used to derive the at-rest encryption key and sign sessions.
# Generate e.g. with: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=change-me-to-a-long-random-secret

# Admin panel credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session lifetime in hours.
SESSION_HOURS=12

# REALITY handshake target and SNI (optional; sensible default is used otherwise).
# Pick a stable TLS site that is geographically close to your exit node.
# REALITY_DEST=www.microsoft.com:443
# REALITY_SNI=www.microsoft.com

# Set to 1 ONLY for local development to bypass the strong-secret requirement.
# APP_ALLOW_INSECURE=0

# Whether session cookies carry the Secure flag (auto-on for non-loopback).
# SESSION_COOKIE_SECURE=1

# Set to 1 ONLY when the app sits behind a reverse proxy that sets/strips
# X-Forwarded-For. Required for correct login rate limiting by client IP.
# TRUST_X_FORWARDED_FOR=1
