# Copy to .env and fill in real values. Never commit the real .env.
# Docker publishes port 8787 publicly by default. Domain/TLS can be added later.

# Optional. Once a domain and HTTPS proxy are configured, uncomment both to
# enable Secure cookies and remove the warning shown in the Web UI.
# PUBLIC_ORIGIN=https://panel.example.com
# ALLOWED_HOSTS=panel.example.com

# Admin account name. Docker reads the two secrets below from
# secrets/app_secret.txt and secrets/admin_password.txt.
ADMIN_USERNAME=admin

# For a non-container install, APP_SECRET/ADMIN_PASSWORD environment variables
# are still supported. Prefer APP_SECRET_FILE and ADMIN_PASSWORD_FILE.

# Session lifetime in hours.
SESSION_HOURS=12
SUBSCRIPTION_RATE_LIMIT=120

# REALITY handshake target and SNI (optional; sensible default is used otherwise).
# Pick a stable TLS site that is geographically close to your exit node.
# REALITY_DEST=www.microsoft.com:443
# REALITY_SNI=www.microsoft.com

# Set to 1 ONLY for local development to bypass the strong-secret requirement.
# APP_ALLOW_INSECURE=0

# Docker publishes on all interfaces by default. Set this to 127.0.0.1 after
# placing Caddy/Nginx on the same host.
# BIND_ADDRESS=127.0.0.1

# Whether session cookies carry the Secure flag (auto-on for an HTTPS origin).
# SESSION_COOKIE_SECURE=1

# Set to 1 ONLY when the app sits behind a reverse proxy that sets/strips
# X-Forwarded-For. Required for correct login rate limiting by client IP.
# TRUST_X_FORWARDED_FOR=1
# TRUSTED_PROXY_IPS=127.0.0.1,::1
